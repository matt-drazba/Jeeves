# Copy to secrets.yaml and fill in values. Never commit secrets.yaml.
# Generate api_encryption_key with: openssl rand -base64 32

wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"
api_encryption_key: "base64-encoded-32-byte-key-here"
ota_password: "choose-a-strong-ota-password"
ap_password: "fallback-ap-password"
